#!/usr/bin/env bash
# =============================================================================
# ocsfx-play — Shared SFX core for all client integrations
# =============================================================================
#
# Resolves theme, picks a random sound for the given category, checks focus,
# and plays the sound. Called by per-client adapter scripts.
#
# Usage:
#   ocsfx-play <category> [options]
#
# Categories:
#   idle        Agent finished a task
#   question    Agent needs user input / permission
#   error       Something went wrong
#   announce    Startup / theme switch
#
# Options:
#   --always        Play even if pane is focused (for announce/test)
#   --theme <name>  Override theme selection
#   --event <name>  Event name for logging
#   --reason <text> Reason for logging
#   --client <name> Client name for logging (opencode, claude, gemini, codex)
#
# Environment:
#   OCSFX_THEME         Force a specific theme
#   OCSFX_SOUNDS_PATH   Custom path to sound files directory
#   OCSFX_ALERT         Tmux alert prefix (default: "!! ")
#   OCSFX_DEBUG          1 = debug logging, test = log without playing
#   OCSFX_LOG_FILE       Write logs to this file
#
# Exit codes:
#   0 - Sound played (or suppressed because pane is focused)
#   1 - Invalid arguments
#   2 - No sounds available for category
#   3 - Theme not found

set -e

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
THEMES_DIR="$PLUGIN_DIR/themes"
BUNDLED_SOUNDS_DIR="$PLUGIN_DIR/sounds"
DEFAULT_SOUNDS_DIR="$HOME/sounds/starcraft/mp3_trimmed"
SOUNDS_DIR="${OCSFX_SOUNDS_PATH:-$DEFAULT_SOUNDS_DIR}"
PLAY_SOUND="$SCRIPT_DIR/play-sound"

STATE_DIR="$HOME/.config/opencode/.opencode-sfx"
INSTANCE_FILE="$STATE_DIR/instances.json"
TTY_PROFILES_FILE="$STATE_DIR/tty-profiles.json"

ALERT_PREFIX="${OCSFX_ALERT:-!! }"

# ---------------------------------------------------------------------------
# Parse arguments
# ---------------------------------------------------------------------------

CATEGORY=""
ALWAYS=false
THEME_OVERRIDE=""
EVENT=""
REASON=""
CLIENT=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --always)    ALWAYS=true; shift ;;
    --theme)     THEME_OVERRIDE="$2"; shift 2 ;;
    --event)     EVENT="$2"; shift 2 ;;
    --reason)    REASON="$2"; shift 2 ;;
    --client)    CLIENT="$2"; shift 2 ;;
    -*)          echo "Unknown option: $1" >&2; exit 1 ;;
    *)
      if [[ -z "$CATEGORY" ]]; then
        CATEGORY="$1"
      else
        echo "Unexpected argument: $1" >&2; exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$CATEGORY" ]]; then
  echo "Usage: ocsfx-play <idle|question|error|announce> [options]" >&2
  exit 1
fi

case "$CATEGORY" in
  idle|question|error|announce) ;;
  *) echo "Unknown category: $CATEGORY (expected idle|question|error|announce)" >&2; exit 1 ;;
esac

# ---------------------------------------------------------------------------
# Debug / logging helpers
# ---------------------------------------------------------------------------

log_debug() {
  local msg="$1"
  local timestamp
  timestamp=$(date '+%Y-%m-%d %H:%M:%S')
  local line="[OCSFX] $timestamp $msg"
  if [[ "$OCSFX_DEBUG" == "1" || "$OCSFX_DEBUG" == "test" ]]; then
    echo "$line" >&2
  fi
  if [[ -n "${OCSFX_LOG_FILE:-}" ]]; then
    echo "$line" >> "$OCSFX_LOG_FILE" 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Theme resolution
# ---------------------------------------------------------------------------

# Parse a YAML theme file and extract sound list for a category.
# Returns newline-separated list of sound filenames.
get_theme_sounds() {
  local theme_file="$1"
  local category="$2"

  if [[ ! -f "$theme_file" ]]; then
    return 1
  fi

  # Simple YAML parser: find the category under "sounds:" and collect values.
  # Handles both single values (announce: foo.mp3) and lists (- foo.mp3).
  local in_sounds=false
  local in_category=false
  local indent=""

  while IFS= read -r line; do
    # Track when we enter "sounds:"
    if [[ "$line" =~ ^sounds: ]]; then
      in_sounds=true
      continue
    fi

    if [[ "$in_sounds" != true ]]; then
      continue
    fi

    # Top-level key under sounds — check if it's our category
    if [[ "$line" =~ ^[[:space:]]{2}([a-z]+):[[:space:]]*(.*) ]]; then
      local key="${BASH_REMATCH[1]}"
      local value="${BASH_REMATCH[2]}"

      if [[ "$key" == "$category" ]]; then
        in_category=true
        # If there's an inline value (not a list), output it
        if [[ -n "$value" && "$value" != "" ]]; then
          echo "$value"
          return 0
        fi
        continue
      else
        # Different key — if we were in our category, we're done
        if [[ "$in_category" == true ]]; then
          return 0
        fi
        in_category=false
        continue
      fi
    fi

    # List items under our category
    if [[ "$in_category" == true && "$line" =~ ^[[:space:]]{4}-[[:space:]]*(.*) ]]; then
      echo "${BASH_REMATCH[1]}"
    fi

    # A non-indented line means we left the sounds block
    if [[ "$in_sounds" == true && ! "$line" =~ ^[[:space:]] && -n "$line" ]]; then
      break
    fi
  done < "$theme_file"
}

# Determine which theme to use. Priority:
# 1. --theme flag
# 2. OCSFX_THEME env var
# 3. .ocsfx file in cwd
# 4. Default theme (for shell adapters, we keep it simple)
resolve_theme() {
  local theme=""

  # 1. Explicit override
  if [[ -n "$THEME_OVERRIDE" ]]; then
    theme="$THEME_OVERRIDE"
  # 2. Environment variable
  elif [[ -n "${OCSFX_THEME:-}" ]]; then
    theme="$OCSFX_THEME"
  # 3. Per-directory file
  elif [[ -f ".ocsfx" ]]; then
    theme="$(cat .ocsfx 2>/dev/null | tr -d '[:space:]')"
  fi

  # Validate theme exists
  if [[ -n "$theme" && -f "$THEMES_DIR/$theme.yaml" ]]; then
    echo "$theme"
    return 0
  fi

  # 4. Fall back to "default" if available, otherwise first theme found
  if [[ -f "$THEMES_DIR/default.yaml" ]]; then
    echo "default"
    return 0
  fi

  # Pick first available theme (excluding test)
  for f in "$THEMES_DIR"/*.yaml; do
    local name
    name="$(basename "$f" .yaml)"
    if [[ "$name" != "test" ]]; then
      echo "$name"
      return 0
    fi
  done

  return 1
}

# Resolve a sound filename to an absolute path.
# Checks user sounds dir first, then bundled sounds.
resolve_sound_path() {
  local filename="$1"

  local user_path="$SOUNDS_DIR/$filename"
  if [[ -f "$user_path" ]]; then
    echo "$user_path"
    return 0
  fi

  local bundled_path="$BUNDLED_SOUNDS_DIR/$filename"
  if [[ -f "$bundled_path" ]]; then
    echo "$bundled_path"
    return 0
  fi

  return 1
}

# Pick a random element from newline-separated input
pick_random() {
  local -a items=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && items+=("$line")
  done

  if [[ ${#items[@]} -eq 0 ]]; then
    return 1
  fi

  local idx=$(( RANDOM % ${#items[@]} ))
  echo "${items[$idx]}"
}

# ---------------------------------------------------------------------------
# Focus detection (simplified version for shell adapters)
# ---------------------------------------------------------------------------

is_pane_active() {
  # In tmux: check if our pane is the active one
  if [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]]; then
    local active
    active=$(tmux display-message -p '#{pane_active}' 2>/dev/null || echo "0")
    if [[ "$active" == "1" ]]; then
      # Pane is active in tmux, but is the terminal itself focused?
      local window_active session_attached
      window_active=$(tmux display-message -p '#{window_active}' 2>/dev/null || echo "0")
      session_attached=$(tmux display-message -p '#{session_attached}' 2>/dev/null || echo "0")
      if [[ "$window_active" == "1" && "$session_attached" -ge 1 ]]; then
        return 0  # pane is active
      fi
    fi
    return 1  # pane is not active
  fi

  # Not in tmux — can't reliably detect focus from a hook script
  # Default to "not focused" so sounds play
  return 1
}

# Set tmux alert prefix on window name
set_tmux_alert() {
  if [[ -z "${TMUX:-}" || -z "${TMUX_PANE:-}" ]]; then
    return
  fi

  local current_name
  current_name=$(tmux display-message -p '#{window_name}' 2>/dev/null) || return

  # Don't add if already has alert prefix
  if [[ "$current_name" == "${ALERT_PREFIX}"* ]]; then
    return
  fi

  tmux rename-window "${ALERT_PREFIX}${current_name}" 2>/dev/null || true
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

# Resolve theme
THEME=$(resolve_theme) || {
  log_debug "ERROR No themes found in $THEMES_DIR"
  exit 3
}

THEME_FILE="$THEMES_DIR/$THEME.yaml"

log_debug "RESOLVE theme=$THEME category=$CATEGORY client=${CLIENT:-shell} event=${EVENT:-$CATEGORY}"

# Get sounds for this category
SOUNDS=$(get_theme_sounds "$THEME_FILE" "$CATEGORY")

if [[ -z "$SOUNDS" ]]; then
  log_debug "SKIP No sounds for category=$CATEGORY in theme=$THEME"
  exit 2
fi

# Pick a random sound
SOUND_FILE=$(echo "$SOUNDS" | pick_random) || {
  log_debug "SKIP Failed to pick random sound for category=$CATEGORY"
  exit 2
}

# Resolve to absolute path
SOUND_PATH=$(resolve_sound_path "$SOUND_FILE") || {
  log_debug "SKIP Sound file not found: $SOUND_FILE"
  exit 2
}

# Focus check (skip for announce/test sounds)
if [[ "$ALWAYS" != true ]]; then
  if is_pane_active; then
    log_debug "SKIP Pane is active, not playing sound"
    exit 0
  fi
fi

# Set tmux alert
if [[ "$ALWAYS" != true ]]; then
  set_tmux_alert
fi

# Play the sound
log_debug "PLAY $SOUND_FILE theme=$THEME category=$CATEGORY client=${CLIENT:-shell} event=${EVENT:-$CATEGORY}"

if [[ "$OCSFX_DEBUG" == "test" ]]; then
  echo "[OCSFX] TEST_MODE: Would play $SOUND_FILE (theme=$THEME, category=$CATEGORY)"
  exit 0
fi

exec "$PLAY_SOUND" \
  --theme "$THEME" \
  --event "${EVENT:-$CATEGORY}" \
  --reason "${REASON:-$CATEGORY}" \
  "$SOUND_PATH"
