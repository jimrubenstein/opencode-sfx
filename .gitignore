# Dependencies
node_modules/

# Build cache
.cache/

# Sound files (user-provided or installed via theme packs, not distributed)
# The sounds/default/ directory IS tracked (bundled synthetic notification tones)
sounds/*
!sounds/default/
*.wav
*.ogg

# Theme packs installed locally (not distributed — install via opencode-sfx install)
# Only default.yaml and test.yaml are tracked in the repo
themes/*
!themes/default.yaml
!themes/test.yaml

# Test sound fixtures (mock files, not real audio)
test/sounds/

# OS files
.DS_Store

# Editor
.idea/
.vscode/
*.swp
*.swo

# TypeScript build output
dist/
*.js
*.js.map
*.d.ts
!lib/*.ts
!plugin.ts

# Lock files (optional - uncomment if you want to include)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
